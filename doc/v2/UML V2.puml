@startuml

' ──────────────────────────────────────────────────────────────
'  V2 – Class Diagram  (GestoreEventi)
'  GREEN  header = NEW    |  ORANGE header = EDITED
'  green text = new member|  orange text   = edited member
' ──────────────────────────────────────────────────────────────

' =====================================================================
'  DIAGRAMMA CLASSI V2 — GestoreEventi
'  Verde  (#D5F5E3)  = classe NUOVA in V2
'  Giallo (#FFF9C4)  = classe MODIFICATA in V2
'  Bianco  = classe INVARIATA da V1
' =====================================================================
skinparam classAttributeIconSize 0
skinparam defaultFontSize 10
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 35

' ═══════════════════════════
' COMPOSITION
' ═══════════════════════════

class Main {
  + main(String[]) : void
}

class Application #FFF9C4 {
  + DATA_CATALOGO : Path
  + DATA_UTENTI : Path
  + <color:green>DATA_PROPOSTE</color> : Path
  __
  + start() : void
}

Main --> Application : create

' ═══════════════════════════
' CONTROLLERS
' ═══════════════════════════

class ConfiguratoreController #FFF9C4 {
  + MENU_CAMPI : String[]
  + MENU_CATEGORIE : String[]
  + MENU_CAMPI_SPECIFICI : String[]
  + MENU_PRINCIPALE : String[]
  - configuratore : Configuratore
  - <color:green>propostaController</color> : PropostaController
  __
  + run() : void
  - mainMenu() : void
  - menuCategorie() : void
  - menuCampiGenerico(String, GestioneCampi) : void
  - menuCampiComuni() : void
  - menuCampiSpecifici(Categoria) : void
  - menuCampiBaseExtra() : void
  - menuVisualizza() : void
  - <color:green>avviaCreazioneProposta()</color> : void
}

class AuthController {
  - auth : AuthenticationService
  __
  + loginConfiguratore() : Configuratore
  - registrazioneInterattiva() : Configuratore
  - raccogliUsername() : String
  - raccogliPassword() : String
}

class PropostaController #D5F5E3 {
  __
  + avviaCreazione(Categoria, List, List) : void
  + pubblicaPropostaSalvata() : void
  + mostraBacheca() : void
  - correggiFinchéValida(Proposta, List) : boolean
  - mostraRiepilogoEPubblica(Proposta) : void
}

' ═══════════════════════════
' APPLICATION SERVICES
' ═══════════════════════════

class CatalogoService {
  - repo : ICatalogoRepository
  __
  + addCampoComune(String, TipoDato, boolean) : void
  + addCampiBaseConExtra(List, List) : void
  + addCampoSpecifico(String, String, TipoDato, boolean) : void
  + initiateCampiBase() : void
  + removeCampoComune(String) : boolean
  + nomeEsistente(String) : boolean
  + removeCampoSpecifico(String, String) : boolean
  + setObbligatorietaCampoComune(String, boolean) : boolean
  + setObbligatorietaCampoSpecifico(String, String, boolean) : boolean
  + getCampiBase() : List
  + getCampiComuni() : List
  + createCategoria(String) : Categoria
  + removeCategoria(String) : boolean
  + getCategorie() : List
  - catalogo() : Catalogo
}

class AuthenticationService {
  + USERNAME_PREDEFINITO : String
  + PASSWORD_PREDEFINITA : String
  - MIN_USERNAME_LENGTH : int
  - MIN_PASSWORD_LENGTH : int
  - repo : ICredenzialiRepository
  __
  + login(String, String) : Optional
  + registraNuovoConfiguratore(String, String) : Configuratore
  + esisteUsername(String) : boolean
  - credenziali() : Credenziali
  - validaCredenziali(String, String) : void
}

class PropostaService #D5F5E3 {
  + CAMPO_TITOLO : String
  + CAMPO_TERMINE_ISCRIZIONE : String
  + CAMPO_DATA : String
  + CAMPO_DATA_CONCLUSIVA : String
  + CAMPO_ORA : String
  + CAMPO_LUOGO : String
  + CAMPO_QUOTA : String
  + CAMPO_NUM_PARTECIPANTI : String
  - bachecaRepo : IBachecaRepository
  - proposteValide : List
  __
  + creaProposta(Categoria, List, List) : Proposta
  + validaProposta(Proposta) : List
  + pubblicaProposta(Proposta) : void
  + salvaProposta(Proposta) : void
  + rimuoviPropostaValida(Proposta) : void
  + clearProposteValide() : void
  + getProposteValide() : List
  + getBacheca() : List
  + getBachecaPerCategoria() : Map
  + getCampiConErrore(Proposta, List) : List
  + {static} isTermineIscrizioneValido(LocalDate) : boolean
  + {static} isDataEventoValida(LocalDate, LocalDate) : boolean
  + {static} isDataConclusivaValida(LocalDate, LocalDate) : boolean
  - bacheca() : Bacheca
  - controllaCampiObbligatori(List, Map, List) : void
  - parseData(String) : LocalDate
  - rilevaDuplicato(Proposta) : void
}

' ═══════════════════════════
' PERSISTENCE — INTERFACES
' ═══════════════════════════

interface ICatalogoRepository {
  + get() : Catalogo
  + save() : void
}

interface ICredenzialiRepository {
  + get() : Credenziali
  + save() : void
}

interface IBachecaRepository #D5F5E3 {
  + get() : Bacheca
  + save() : void
}

' ═══════════════════════════
' PERSISTENCE — IMPL
' ═══════════════════════════

abstract class AbstractFileRepository {
  - path : Path
  - type : Class
  - defaultValue : Supplier
  __
  # load() : T
  # save(T) : void
}

class FileCatalogoRepository {
  - cached : Catalogo
  __
  + get() : Catalogo
  + save() : void
}

class FileCredenzialiRepository {
  - cached : Credenziali
  __
  + get() : Credenziali
  + save() : void
}

class FileBachecaRepository #D5F5E3 {
  - cached : Bacheca
  __
  + get() : Bacheca
  + save() : void
}

' ═══════════════════════════
' DOMAIN — INVARIATE (V1)
' ═══════════════════════════

class Catalogo {
  - campiBaseFissati : boolean
  - campiComuni : List
  - campiBase : List
  - categorie : List
  __
  + fissareCampiBase(List, List) : void
  + isCampiBaseFissati() : boolean
  + addCampoComune(Campo) : void
  + removeCampoComune(String) : boolean
  + updateCampoComune(String, boolean) : boolean
  + addCategoria(String) : Categoria
  + removeCategoria(String) : boolean
  + getCategoriaOrThrow(String) : Categoria
  + addCampoSpecifico(String, Campo) : void
  + removeCampoSpecifico(String, String) : boolean
  + updateCampoSpecifico(String, String, boolean) : boolean
  + getCampiBase() : List
  + getCampiComuni() : List
  + getCategorie() : List
  + nomeEsistenteGlobale(String) : boolean
  - addNomeUnico(Set, String) : void
  - findCategoria(String) : Optional
}

class Categoria {
  - nome : String
  - campiSpecifici : List
  __
  + getNome() : String
  + getCampiSpecifici() : List
  + addCampoSpecifico(Campo) : void
  + removeCampoSpecifico(String) : boolean
  + setObbligatorietaCampoSpecifico(String, boolean) : boolean
  - containsCampo(String) : boolean
  + equals(Object) : boolean
  + hashCode() : int
}

class Campo {
  - nome : String
  - tipo : TipoCampo
  - tipoDato : TipoDato
  - obbligatorio : boolean
  __
  + getNome() : String
  + getTipo() : TipoCampo
  + getTipoDato() : TipoDato
  + isObbligatorio() : boolean
  + withObbligatorio(boolean) : Campo
  + equals(Object) : boolean
  + hashCode() : int
}

enum CampoBaseDefinito {
  + TITOLO
  + NUMERO_PARTECIPANTI
  + TERMINE_ISCRIZIONE
  + LUOGO
  + DATA
  + ORA
  + QUOTA_INDIVIDUALE
  + DATA_CONCLUSIVA
  __
  + getNomeCampo() : String
  + getTipoDato() : TipoDato
  + toCampo() : Campo
  + {static} fromNome(String) : CampoBaseDefinito
  + {static} isNomeFisso(String) : boolean
}

abstract class Persona {
  - username : String
  __
  # getUsername() : String
  + equals(Object) : boolean
  + hashCode() : int
  + toString() : String
}

class Configuratore {
}

class Credenziali {
  - configuratori : Map
  __
  + getConfiguratori() : Map
  + addConfiguratore(String, String) : void
}

enum TipoCampo {
  + BASE
  + COMUNE
  + SPECIFICO
}

enum TipoDato {
  + STRINGA
  + INTERO
  + DECIMALE
  + DATA
  + ORA
  + BOOLEANO
}

' ═══════════════════════════
' DOMAIN — NUOVE V2
' ═══════════════════════════

class Proposta #D5F5E3 {
  - campiBase : List
  - campiComuni : List
  - categoria : Categoria
  - valoriCampi : Map
  - stato : StatoProposta
  - dataPubblicazione : LocalDate
  - termineIscrizione : LocalDate
  - dataEvento : LocalDate
  __
  + getCategoria() : Categoria
  + getCampi() : List
  + getStato() : StatoProposta
  + getDataPubblicazione() : LocalDate
  + getTermineIscrizione() : LocalDate
  + getDataEvento() : LocalDate
  + getValoriCampi() : Map
  + putAllValoriCampi(Map) : void
  + setStato(StatoProposta) : void
  + setDataPubblicazione(LocalDate) : void
  + setTermineIscrizione(LocalDate) : void
  + setDataEvento(LocalDate) : void
  + {static} fromJson(...) : Proposta
}

class Bacheca #D5F5E3 {
  - proposte : List
  __
  + getProposte() : List
  + addProposta(Proposta) : void
  + {static} fromJson(List) : Bacheca
}

enum StatoProposta #D5F5E3 {
  + BOZZA
  + VALIDA
  + APERTA
  __
  + canTransitionTo(StatoProposta) : boolean
}

class AppConstants #D5F5E3 {
  + {static} DATE_FORMAT_LABEL : String
  + {static} TIME_FORMAT_LABEL : String
  + {static} DATE_FMT : DateTimeFormatter
  + {static} TIME_FMT : DateTimeFormatter
}

