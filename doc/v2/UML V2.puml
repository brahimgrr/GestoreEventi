' VIEW — CLI + FORM SYSTEM
' ═══════════════════════════

together {
  class ConsoleUI #FFF9C4 {
    - scanner : Scanner
    + CANCEL_KEYWORD : String
    + BACK_KEYWORD : String
    + HINT_ANNULLA : String
    __
    + stampa(String) : void
    + newLine() : void
    + header(String) : void
    + stampaSezione(String) : void
    + stampaCampi(List) : void
    + stampaCategorie(List) : void
    + stampaCategorieDettaglio(Map) : void
    + stampaMenu(String, String[]) : void
    + stampaMenu(String, String[], String) : void
    + pausa() : void
    + stampaSuccesso(String) : void
    + stampaErrore(String) : void
    + stampaAvviso(String) : void
    + stampaInfo(String) : void
    + pausaConSpaziatura() : void
    + acquisisciStringa(String) : String
    + acquisisciStringaConValidazione(String, Predicate, String) : String
    + acquisisciPassword(String) : String
    + acquisisciIntero(String, int, int) : int
    + acquisisciSiNo(String) : boolean
    + acquisisciTipoDato(String) : TipoDato
    + acquisisciListaNomi(String) : List
    + selezionaElemento(String, List) : Optional
    + selezionaElementoConInfo(String, List, Function) : Optional
    + <color:green>selezionaCategoria(List<Categoria>)</color> : OptionalInt
    + <color:green>acquisisciValoriProposta(Proposta, ProposalFieldValidator)</color> : Optional
    + <color:green>correggiCampiProposta(Proposta, Set, ProposalFieldValidator)</color> : Optional
    + <color:green>mostraBacheca(Map<String, List<Proposta>>)</color> : void
    + <color:green>mostraRiepilogoProposta(Proposta)</color> : void
  }

  interface TypeValidator #D5F5E3 {
    + validate(String, TipoDato) : String
  }

  class DefaultTypeValidator #D5F5E3 {
    + {static} INSTANCE : DefaultTypeValidator
    __
    + validate(String, TipoDato) : String
    - validateIntero(String) : String
    - validateDecimale(String) : String
    - validateData(String) : String
    - validateOra(String) : String
    - validateBooleano(String) : String
  }
}

