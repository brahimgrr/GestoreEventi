' ═══════════════════════════════════════
'  RELAZIONI
' ═══════════════════════════════════════

' --- Composition root ---
Application ..> AuthenticationService : create
Application ..> CatalogoService : create
Application ..> PropostaService : create
Application ..> AuthController : create
Application ..> ConfiguratoreController : create
Application ..> PropostaController : create
Application ..> ConsoleUI : create
Application ..> FileCatalogoRepository : create
Application ..> FileCredenzialiRepository : create
Application ..> FileBachecaRepository : create

' --- Ereditarietà ---
Configuratore --|> Persona
OperationCancelledException --|> RuntimeException
CancelException --|> OperationCancelledException
BackException --|> OperationCancelledException

' --- Interfacce view ---
IAppView --|> IOutputView
IAppView --|> IInputView
ConsoleUI ..|> IAppView

' --- Persistence: implementazioni ---
FileCatalogoRepository --|> AbstractFileRepository
FileCredenzialiRepository --|> AbstractFileRepository
FileBachecaRepository --|> AbstractFileRepository
FileCatalogoRepository ..|> ICatalogoRepository
FileCredenzialiRepository ..|> ICredenzialiRepository
FileBachecaRepository ..|> IBachecaRepository

' --- Repository stores Domain ---
FileCatalogoRepository --> Catalogo : stores
FileCredenzialiRepository --> Credenziali : stores
FileBachecaRepository --> Bacheca : stores

' --- Controller -> View ---
ConfiguratoreController "1" --> "1" IAppView
AuthController "1" --> "1" IAppView
PropostaController "1" --> "1" IAppView

' --- Controller -> Service ---
ConfiguratoreController "1" --> "1" CatalogoService
ConfiguratoreController "1" --> "1" PropostaController
AuthController "1" --> "1" AuthenticationService
PropostaController "1" --> "1" PropostaService

' --- Controller -> Domain ---
ConfiguratoreController --> Configuratore : configuratore

' --- Service -> Repository ---
CatalogoService "1" --> "1" ICatalogoRepository : repo
AuthenticationService "1" --> "1" ICredenzialiRepository : repo
PropostaService "1" --> "1" IBachecaRepository : bachecaRepo

' --- Domain: Catalogo ---
Catalogo "1" *-- "*" Campo : campiBase
Catalogo "1" *-- "*" Campo : campiComuni
Catalogo "1" *-- "*" Categoria : categorie

' --- Domain: Categoria ---
Categoria "1" *-- "*" Campo : campiSpecifici

' --- Domain: Campo ---
Campo --> TipoCampo : tipo
Campo --> TipoDato : tipoDato
CampoBaseDefinito --> TipoDato : tipoDato
CampoBaseDefinito ..> Campo : create

' --- Domain: Proposta ---
Proposta "1" --> "1" Categoria : categoria
Proposta "1" --> "1" StatoProposta : stato
Proposta "1" --> "*" Campo : campiBase
Proposta "1" --> "*" Campo : campiComuni

' --- Domain: Bacheca ---
Bacheca "1" *-- "*" Proposta : proposte

' --- ConsoleUI -> View validation ---
ConsoleUI ..> DefaultTypeValidator : uses
ConsoleUI ..> ProposalFieldValidator : uses

' --- View validation ---
DefaultTypeValidator ..|> TypeValidator
PropostaController ..> ProposalFieldValidator : passes callback

@enduml
